# Reown (WalletConnect) Project ID
# Get yours at https://cloud.reown.com
NEXT_PUBLIC_PROJECT_ID=your_project_id_here

# Smart Contract Addresses (CrossFi Testnet)
NEXT_PUBLIC_DAO_CONTRACT_ADDRESS=0x...
NEXT_PUBLIC_FARM_CONTRACT_ADDRESS=0x...
NEXT_PUBLIC_FARM_ESCROW_CONTRACT_ADDRESS=0x...
NEXT_PUBLIC_INVESTMENT_CONTRACT_ADDRESS=0x...
NEXT_PUBLIC_TOKEN_CONTRACT_ADDRESS=0x...

# Pinata IPFS Configuration
# Get yours at https://app.pinata.cloud/developers/api-keys
NEXT_PUBLIC_PINATA_API_KEY=your_pinata_api_key
NEXT_PUBLIC_PINATA_API_SECRET_KEY=your_pinata_secret_key
